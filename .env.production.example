# Database
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=

# Security - MUST change for production
# Generate with: openssl rand -hex 32
JWT_SECRET=
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Default API keys (optional - users can store their own via BYOK)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Email verification (required for production)
# Get your API key from https://resend.com
RESEND_API_KEY=

# Cloudflare Tunnel
# Get from: Cloudflare Dashboard -> Zero Trust -> Tunnels -> Create
CLOUDFLARE_TUNNEL_TOKEN=

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=https://designfast.app,https://api.designfast.app

# OAuth - Google (optional)
# Get credentials from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth - GitHub (optional)
# Get credentials from https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth callback URL (your backend's public URL)
OAUTH_CALLBACK_URL=https://api.designfast.app
