# Database
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=

# Security - MUST change for production
# Generate with: openssl rand -hex 32
JWT_SECRET=
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Default API keys (optional - users can store their own via BYOK)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Cloudflare Tunnel
# Get from: Cloudflare Dashboard -> Zero Trust -> Tunnels -> Create
CLOUDFLARE_TUNNEL_TOKEN=
