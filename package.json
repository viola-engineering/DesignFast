{
  "name": "ve-designfast",
  "version": "0.1.4",
  "type": "module",
  "scripts": {
    "release": "node scripts/release.js",
    "start": "node -r dotenv/config backend/src/server.js",
    "migrate": "node -r dotenv/config backend/src/migrate.js",
    "test": "node -r dotenv/config --test --test-concurrency=1 'backend/test/*.test.js'",
    "generate-examples": "node -r dotenv/config backend/scripts/generate-style-examples.js",
    "generate-screenshots": "node backend/scripts/generate-screenshots.js"
  },
  "dependencies": {
    "@angycode/core": "0.1.3",
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/multipart": "^9.4.0",
    "archiver": "^7.0.1",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "image-size": "^2.0.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "queen-mq": "latest",
    "resend": "^6.10.0",
    "stripe": "^17.5.0"
  },
  "devDependencies": {
    "puppeteer": "^24.0.0"
  }
}
