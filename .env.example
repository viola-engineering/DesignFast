# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# Queen job queue server URL
QUEEN_URL=http://localhost:6632

# Secret used to sign JWT auth tokens (change in production!)
JWT_SECRET=

# 256-bit hex key for AES-256-GCM encryption of stored API keys (change in production!)
ENCRYPTION_KEY=

# Default API keys (optional — users can also store their own via BYOK)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Email verification (optional — if not set, email verification is disabled)
# Get your API key from https://resend.com
RESEND_API_KEY=

# OAuth - Google (optional — if not set, Google OAuth is disabled)
# Get credentials from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth - GitHub (optional — if not set, GitHub OAuth is disabled)
# Get credentials from https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth callback URL (required for OAuth — the backend's public URL)
# Example: https://api.designfast.app or http://localhost:3000
OAUTH_CALLBACK_URL=

# Stripe (for credit purchases)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Base URL for redirects (defaults to http://localhost:5173)
BASE_URL=

# Allowed CORS origins (comma-separated, defaults to designfast.app + localhost)
# ALLOWED_ORIGINS=https://designfast.app,https://api.designfast.app,http://localhost:5173

# Server listen port
PORT=3000
